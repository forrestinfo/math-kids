{
  "name": "math-kids",
  "version": "1.0.0",
  "description": "儿童计算小程序 - 美乐蒂风格",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --config electron-builder.json",
    "build:win:x64": "vite build && electron-builder --win --x64",
    "build:win:arm64": "vite build && electron-builder --win --arm64",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["electron", "math", "kids", "education"],
  "author": "forrest",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {}
}
